{
  "$schema": "https://schemas.figma.com/tokens/v1.json",
  "brand": {
    "name": "eBay Price Sentry",
    "personality": ["professional", "trustworthy", "data-focused"]
  },
  "colors": {
    "neutral": {
      "background": "#FFFFFF",
      "surface": "#F9FAFB",
      "border": "#E5E7EB",
      "border-strong": "#D1D5DB",
      "text-primary": "#111827",
      "text-secondary": "#6B7280",
      "text-tertiary": "#9CA3AF",
      "text-disabled": "#D1D5DB"
    },
    "sidebar": {
      "background": "#0F172A",
      "background-hover": "#1E293B",
      "text": "#E2E8F0",
      "text-active": "#FFFFFF",
      "active-bg": "#2563EB",
      "active-bg-soft": "#1E40AF"
    },
    "primary": {
      "DEFAULT": "#2563EB",
      "hover": "#1D4ED8",
      "active": "#1E40AF",
      "subtle": "#DBEAFE",
      "subtle-hover": "#BFDBFE",
      "text-on-primary": "#FFFFFF"
    },
    "status": {
      "success": {
        "DEFAULT": "#10B981",
        "background": "#D1FAE5",
        "text": "#065F46",
        "border": "#A7F3D0"
      },
      "warning": {
        "DEFAULT": "#F59E0B",
        "background": "#FEF3C7",
        "text": "#92400E",
        "border": "#FDE68A"
      },
      "error": {
        "DEFAULT": "#EF4444",
        "background": "#FEE2E2",
        "text": "#991B1B",
        "border": "#FECACA"
      },
      "neutral": {
        "DEFAULT": "#6B7280",
        "background": "#F3F4F6",
        "text": "#374151",
        "border": "#E5E7EB"
      }
    },
    "data": {
      "positive": "#10B981",
      "negative": "#EF4444",
      "highlight": "#FBBF24"
    }
  },
  "darkMode": {
    "supported": false,
    "note": "未対応。将来追加予定の場合はここに dark バリアントを追加"
  }
}
